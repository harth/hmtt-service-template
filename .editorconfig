root = true

# ── All files ─────────────────────────────────────────────────────────────────
[*]
charset               = utf-8
end_of_line           = lf
trim_trailing_whitespace = true
insert_final_newline  = true

# ── Java source files ─────────────────────────────────────────────────────────
[*.java]
indent_style = space
indent_size  = 4

# ── Gradle build files ────────────────────────────────────────────────────────
[*.gradle]
indent_style = space
indent_size  = 4

# ── YAML configuration files ──────────────────────────────────────────────────
[*.{yml,yaml}]
indent_style = space
indent_size  = 2

# ── XML files ─────────────────────────────────────────────────────────────────
[*.xml]
indent_style = space
indent_size  = 4

# ── Markdown files (preserve trailing whitespace — used for line breaks) ──────
[*.md]
trim_trailing_whitespace = false

# ── Properties files ──────────────────────────────────────────────────────────
[*.properties]
indent_style = space
indent_size  = 4
